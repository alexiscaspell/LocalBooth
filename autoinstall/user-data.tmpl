#cloud-config
autoinstall:
  version: 1

  # ── Locale & keyboard ────────────────────────────────────────────────
  locale: en_US.UTF-8
  keyboard:
    layout: us

  # ── Network ──────────────────────────────────────────────────────────
  # In online mode the installer uses DHCP by default.
  # In offline mode network is disabled to prevent APT from reaching
  # the internet.
  network:
    version: 2
    ethernets: {}

  # ── Storage — use the entire disk, LVM ───────────────────────────────
  storage:
    layout:
      name: lvm

  # ── Identity ─────────────────────────────────────────────────────────
  identity:
    hostname: localbooth
    username: dev
    # Password: "changeme"
    # Generate a new hash on Ubuntu: openssl passwd -6 "your-password"
    password: "$6$xyz$PLACEHOLDER_HASH"

  # ── SSH ──────────────────────────────────────────────────────────────
  ssh:
    install-server: true
    allow-pw: true

  # ════════════════════════════════════════════════════════════════════
  # ONLINE MODE — packages downloaded from the internet during install.
  # The machine MUST have network access.
  # ════════════════════════════════════════════════════════════════════
  #
  # packages:
  #   - docker.io
  #   - git
  #   - curl
  #   - build-essential
  #   - jq
  #   - unzip
  #   - htop
  #   - ca-certificates
  #   - gnupg
  #   - openssh-server
  #
  # late-commands:
  #   - cp /cdrom/bootstrap/bootstrap.sh /target/tmp/bootstrap.sh
  #   - chmod +x /target/tmp/bootstrap.sh
  #   - curtin in-target --target=/target -- /tmp/bootstrap.sh

  # ════════════════════════════════════════════════════════════════════
  # OFFLINE MODE — packages installed from the local repo on the USB.
  # No network needed.
  # ════════════════════════════════════════════════════════════════════
  #
  # updates: security
  # package_update: false
  # package_upgrade: false
  #
  # late-commands:
  #   - mv /target/etc/apt/sources.list.d/ubuntu.sources /target/etc/apt/sources.list.d/ubuntu.sources.bak || true
  #   - echo 'deb [trusted=yes] file:///mnt/repo ./' > /target/etc/apt/sources.list
  #   - mkdir -p /target/mnt/repo
  #   - mount --bind /cdrom/repo /target/mnt/repo
  #   - curtin in-target --target=/target -- apt-get update
  #   - curtin in-target --target=/target -- apt-get install -y --no-install-recommends docker.io git curl ...
  #   - umount /target/mnt/repo
  #   - rm -f /target/etc/apt/sources.list
  #   - mv /target/etc/apt/sources.list.d/ubuntu.sources.bak /target/etc/apt/sources.list.d/ubuntu.sources || true
  #   - cp /cdrom/bootstrap/bootstrap.sh /target/tmp/bootstrap.sh
  #   - chmod +x /target/tmp/bootstrap.sh
  #   - curtin in-target --target=/target -- /tmp/bootstrap.sh

  # ── Reboot automatically when done ──────────────────────────────────
  shutdown: reboot
